{
  "name": "how-to-graph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "demo:record": "node scripts/record-demo.mjs",
    "demo:record:plan": "node scripts/record-demo.mjs --scenario=plan",
    "demo:record:table": "node scripts/record-demo.mjs --scenario=table",
    "demo:record:graph": "node scripts/record-demo.mjs --scenario=graph",
    "codex:context": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/codex-context.ps1",
    "codex:verify": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/codex-verify.ps1"
  },
  "dependencies": {
    "@vitejs/plugin-legacy": "^7.2.1",
    "@vitejs/plugin-react": "^5.1.1",
    "jsqr": "^1.4.0",
    "lucide-react": "^1.17.0",
    "lz-string": "^1.5.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "vite": "^7.2.6"
  },
  "devDependencies": {
    "ffmpeg-static": "^5.3.0",
    "playwright": "^1.60.0",
    "terser": "^5.44.1"
  },
  "browserslist": [
    "Safari >= 12",
    "iOS >= 12",
    "last 2 Chrome versions",
    "last 2 Edge versions"
  ]
}
